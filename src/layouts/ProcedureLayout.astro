---
import BaseLayout from './BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Faq from '../components/Faq.astro';
import RelatedProcedures from '../components/RelatedProcedures.astro';
import { relatedProcedures, type Procedure } from '../data/procedures';
import { SITE } from '../consts';
interface Props { procedure: Procedure; }
const { procedure } = Astro.props;
const related = relatedProcedures(procedure.slug, 3);
const heroKey = procedure.category.toLowerCase().replace(/\s+/g, '').replace('non-surgical', 'nonsurgical');

const medicalLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalProcedure',
  name: procedure.title,
  alternateName: procedure.title.replace(/\s*\([^)]+\)\s*/g, '').trim(),
  description: procedure.overview || procedure.blurb,
  procedureType: 'http://schema.org/SurgicalProcedure',
  ...(procedure.bodyLocation ? { bodyLocation: procedure.bodyLocation } : {}),
  url: new URL(`/procedures/${procedure.slug}/`, SITE.url).toString(),
  performer: {
    '@type': 'Physician',
    name: SITE.doctor,
    url: SITE.url,
    telephone: SITE.phone,
    medicalSpecialty: 'Plastic Surgery',
    address: {
      '@type': 'PostalAddress',
      streetAddress: SITE.address.street,
      addressLocality: SITE.address.city,
      addressRegion: SITE.address.state,
      postalCode: SITE.address.zip,
      addressCountry: 'US',
    },
  },
  ...(procedure.recovery ? { followup: `Typical recovery: ${procedure.recovery}` } : {}),
};
---
<BaseLayout title={procedure.title} description={procedure.blurb}>
  <section class="procedure-hero">
    <div class="container procedure-hero-grid">
      <div class="procedure-hero-copy">
        <Breadcrumbs items={[
          { label: 'Home', href: '/' },
          { label: 'Procedures', href: '/procedures/' },
          { label: procedure.title },
        ]} />
        <p class="eyebrow reveal">{procedure.category}</p>
        <h1 class="reveal">{procedure.title}</h1>
        <p class="lead reveal">{procedure.blurb}</p>
        {(procedure.duration || procedure.recovery) && (
          <div class="meta reveal">
            {procedure.duration && <div><span class="meta-label">Duration</span><span class="meta-value">{procedure.duration}</span></div>}
            {procedure.recovery && <div><span class="meta-label">Recovery</span><span class="meta-value">{procedure.recovery}</span></div>}
          </div>
        )}
      </div>
      <figure class="procedure-hero-art reveal" data-parallax="50">
        <picture>
          <source srcset={`/assets/procedures/hero-${heroKey}.avif`} type="image/avif" />
          <img
            src={`/assets/procedures/hero-${heroKey}.jpg`}
            alt={`${procedure.category} editorial`}
            width="1000"
            height="450"
            loading="eager"
            fetchpriority="high"
          />
        </picture>
      </figure>
    </div>
  </section>

  <section class="dark-section section">
    <div class="container content-grid">
      <div class="reveal">
        <p class="eyebrow on-dark">Overview</p>
        <h2>An approach defined by precision.</h2>
        <p class="lead">{procedure.overview || `Every ${procedure.title.toLowerCase()} at Desai Plastic Surgery begins with an in-depth conversation about your goals, your anatomy, and your lifestyle. Dr. Desai's training across Harvard, Brown, Tufts, and the Beverly Hills Institute of Plastic Surgery informs a singularly methodical approach.`}</p>
      </div>
      <div class="content-list reveal">
        <div>
          <h3>Candidacy</h3>
          <p>{procedure.candidacy || 'Ideal candidates are in good general health, have realistic expectations, and seek refinement rather than reinvention.'}</p>
        </div>
        <div>
          <h3>The Procedure</h3>
          <p>{procedure.technique || 'Performed under appropriate anesthesia in an accredited facility, with techniques tailored to your individual anatomy.'}</p>
        </div>
        <div>
          <h3>Recovery</h3>
          <p>{procedure.recoveryDetail || `Most patients return to social activities within ${procedure.recovery || 'one to two weeks'}. A detailed recovery roadmap is provided at your consultation.`}</p>
        </div>
        <div>
          <h3>Results</h3>
          <p>{procedure.results || "Outcomes are natural, proportionate, and built to age gracefully — the hallmark of Dr. Desai's aesthetic."}</p>
        </div>
      </div>
    </div>
  </section>

  {procedure.faqs && procedure.faqs.length > 0 && (
    <Faq items={procedure.faqs} heading={`${procedure.title} — questions patients ask.`} />
  )}

  <RelatedProcedures items={related} category={procedure.category} />

  <CTASection />
</BaseLayout>

<script type="application/ld+json" set:html={JSON.stringify(medicalLd)} />

<style>
  .procedure-hero { padding: clamp(56px, 7vw, 80px) 0 clamp(80px, 12vw, 140px); background: var(--paper); }
  .procedure-hero-grid { display: grid; grid-template-columns: 1.1fr 1fr; gap: clamp(40px, 5vw, 80px); align-items: end; }
  .procedure-hero-copy h1 { margin: 18px 0 28px; max-width: 16ch; font-size: clamp(3rem, 7.5vw, 6.25rem); font-weight: 320; letter-spacing: -0.035em; line-height: 0.96; }
  .procedure-hero h1 { font-size: clamp(3rem, 7.5vw, 6.25rem); }
  .procedure-hero .lead { max-width: 50ch; }
  .procedure-hero .crumbs { margin-bottom: 56px; }
  .procedure-hero-art { margin: 0; aspect-ratio: 10/9; overflow: hidden; border: 1px solid var(--line); }
  .procedure-hero-art img { width: 100%; height: 100%; object-fit: cover; display: block; }
  @media (max-width: 900px) { .procedure-hero-grid { grid-template-columns: 1fr; } .procedure-hero-art { order: -1; aspect-ratio: 16/9; } }

  /* Extra breathing for the detailed content block on procedure pages */
  .dark-section.section {
    padding-bottom: clamp(72px, 9vw, 96px);
  }
  .meta { display: flex; gap: 64px; margin-top: 56px; padding-top: 36px; border-top: 1px solid var(--line); }
  .meta div { display: flex; flex-direction: column; gap: 8px; }
  .meta-label { font-size: 0.62rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--grey-500); font-weight: 600; }
  .meta-value { font-family: var(--font-display); font-size: 1.55rem; font-variation-settings: 'opsz' 144, 'SOFT' 0; font-weight: 360; color: var(--ink); letter-spacing: -0.02em; }
  .content-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(48px, 8vw, 112px); align-items: start; }

  /* Long-form readability improvements — targeted to procedure detail pages */
  .content-grid .lead {
    line-height: 1.68;
    max-width: 58ch;
  }

  .content-list {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .content-list h3 {
    color: var(--paper);
    margin-bottom: 12px;
    font-size: 1.2rem;
    font-weight: 380;
    letter-spacing: -0.01em;
    line-height: 1.35;
  }

  .content-list p {
    color: var(--grey-300);
    line-height: 1.68;
    max-width: 52ch;
    font-size: 0.96rem;
  }

  @media (max-width: 800px) {
    .content-grid { grid-template-columns: 1fr; }
    .content-list p { max-width: none; }
  }

  /* ── Print styles ──────────────────────────────────────────── */
  @media print {
    :global(.site-header), :global(.sticky-cta), :global(.search-trigger),
    :global(.btn), :global(.cta-section), :global(.related), :global(footer.footer),
    :global(.crumbs .sep + li), :global(nav.crumbs) { display: none !important; }
    :global(body) { background: white; color: #111; }
    :global(.dark-section) { background: white !important; color: #111 !important; }
    :global(.dark-section h1), :global(.dark-section h2), :global(.dark-section h3),
    :global(.dark-section p), :global(.dark-section .lead) { color: #111 !important; }
    :global(.faq-item details) { padding: 8px 0; }
    :global(.faq-item details[open] .ico), :global(.faq-item .ico) { display: none; }
    :global(.faq-item details) summary { font-weight: 600; }
    :global(.reveal) { opacity: 1 !important; transform: none !important; }
    .procedure-hero { padding-top: 0; }
  }
</style>
