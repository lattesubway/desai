---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';
import FilterBar from '../components/FilterBar.astro';

const gallery = [
  { cat: 'Nose',   title: 'Primary Rhinoplasty',          age: '20s', slug: 'rhinoplasty-primary' },
  { cat: 'Nose',   title: 'Revision Rhinoplasty',         age: '30s', slug: 'rhinoplasty-revision' },
  { cat: 'Face',   title: 'Facelift & Neck Lift',         age: '50s', slug: 'facelift-necklift' },
  { cat: 'Face',   title: 'Upper & Lower Blepharoplasty', age: '40s', slug: 'blepharoplasty' },
  { cat: 'Breast', title: 'Breast Augmentation',          age: '30s', slug: 'augmentation' },
  { cat: 'Breast', title: 'Mastopexy with Augmentation',  age: '40s', slug: 'mastopexy-aug' },
  { cat: 'Body',   title: 'Tummy Tuck & Liposuction',     age: '30s', slug: 'tummy-tuck-lipo' },
  { cat: 'Body',   title: 'Mommy Makeover',               age: '30s', slug: 'mommy-makeover' },
  { cat: 'Face',   title: 'Stem Cell Facelift',           age: '50s', slug: 'stem-cell' },
  { cat: 'Body',   title: 'Brazilian Butt Lift',          age: '20s', slug: 'bbl' },
  { cat: 'Nose',   title: 'Ethnic Rhinoplasty',           age: '20s', slug: 'ethnic-rhinoplasty' },
  { cat: 'Breast', title: 'Breast Reduction',             age: '30s', slug: 'reduction' },
];
const cats = ['All', 'Face', 'Nose', 'Breast', 'Body'];
const W = 1200;
const H = 900;
---
<BaseLayout title="Gallery" description="Before and after results from Dr. Urmen Desai's Beverly Hills plastic surgery practice.">
  <section class="g-hero">
    <div class="container">
      <p class="eyebrow reveal">Before & After</p>
      <h1 class="reveal">Real patients. <em>Real results.</em></h1>
      <p class="lead reveal">A curated selection from Dr. Desai's private gallery. Open any case to compare before and after in detail. Models pictured may not be actual patients of this practice.</p>
    </div>
  </section>

  <section class="g-filter section-tight">
    <div class="container">
      <FilterBar categories={cats} label="Filter gallery" />
    </div>
  </section>

  <section class="g-list section">
    <div class="container">
      <div class="g-grid" id="g-grid">
        {gallery.map((item, i) => (
          <article class="g-item reveal" data-cat={item.cat} style={`transition-delay:${(i%6)*60}ms`}>
            <div class="g-thumb-wrap">
              <a
                class="g-thumb-link"
                href={`/assets/gallery/${item.slug}-after.jpg`}
                data-pswp-width={W}
                data-pswp-height={H}
                data-pswp-srcset={`/assets/gallery/${item.slug}-after.avif 1200w`}
                aria-label={`${item.title} — open before/after view`}
              >
                <div class="g-thumb">
                  <picture class="g-half g-before">
                    <source srcset={`/assets/gallery/${item.slug}-before.avif`} type="image/avif" />
                    <img src={`/assets/gallery/${item.slug}-before.jpg`} alt={`${item.title} — before`} loading="lazy" width="600" height="900" />
                    <span class="g-label">Before</span>
                  </picture>
                  <picture class="g-half g-after">
                    <source srcset={`/assets/gallery/${item.slug}-after.avif`} type="image/avif" />
                    <img src={`/assets/gallery/${item.slug}-after.jpg`} alt={`${item.title} — after`} loading="lazy" width="600" height="900" />
                    <span class="g-label">After</span>
                  </picture>
                </div>
              </a>
              <a
                class="g-pair-link"
                href={`/assets/gallery/${item.slug}-before.jpg`}
                data-pswp-width={W}
                data-pswp-height={H}
                data-pswp-srcset={`/assets/gallery/${item.slug}-before.avif 1200w`}
                aria-hidden="true"
                tabindex="-1"
              ></a>
            </div>
            <div class="g-meta">
              <span class="g-cat">{item.cat}</span>
              <h3>{item.title}</h3>
              <span class="g-age">Patient, {item.age}</span>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<script>
  import PhotoSwipeLightbox from 'photoswipe/lightbox';
  import 'photoswipe/style.css';

  let lightbox: any = null;

  const init = () => {
    if (lightbox) { lightbox.destroy(); lightbox = null; }
    const grid = document.getElementById('g-grid');
    if (!grid) return;

    lightbox = new PhotoSwipeLightbox({
      gallery: '#g-grid .g-item .g-thumb-wrap',
      children: 'a',
      pswpModule: () => import('photoswipe'),
      bgOpacity: 0.94,
      showHideAnimationType: 'fade',
      padding: { top: 56, bottom: 56, left: 24, right: 24 },
    });

    lightbox.on('uiRegister', () => {
      lightbox.pswp.ui.registerElement({
        name: 'caption',
        order: 9,
        isButton: false,
        appendTo: 'root',
        html: '',
        onInit: (el: HTMLElement) => {
          lightbox.pswp.on('change', () => {
            const slide = lightbox.pswp.currSlide;
            const a = slide?.data?.element as HTMLElement | undefined;
            const card = a?.closest('.g-item');
            if (!card) { el.innerHTML = ''; return; }
            const title = card.querySelector('h3')?.textContent ?? '';
            const cat = card.querySelector('.g-cat')?.textContent ?? '';
            const age = card.querySelector('.g-age')?.textContent ?? '';
            const isBefore = a?.classList.contains('g-pair-link');
            const label = isBefore ? 'BEFORE' : 'AFTER';
            el.innerHTML = `
              <div class="pswp__caption">
                <span class="cap-step">${label}</span>
                <span class="cap-cat">${cat}</span>
                <span class="cap-title">${title}</span>
                <span class="cap-age">${age}</span>
              </div>`;
          });
        },
      });
    });

    lightbox.init();
  };

  // Filter-bar integration: hide cards whose data-cat doesn't match
  const initFilter = () => {
    const btns = document.querySelectorAll('.filter-btn');
    const items = document.querySelectorAll('.g-item');
    btns.forEach((b) => b.addEventListener('click', () => {
      btns.forEach((x) => x.classList.remove('active'));
      b.classList.add('active');
      const f = b.getAttribute('data-filter');
      items.forEach((i) =>
        i.classList.toggle('g-hidden', f !== 'All' && i.getAttribute('data-cat') !== f),
      );
    }));
  };

  init();
  initFilter();
  document.addEventListener('astro:after-swap', () => { init(); initFilter(); });
</script>

<style>
  .g-hero { padding: clamp(96px, 14vw, 160px) 0 clamp(48px, 6vw, 80px); }
  .g-hero h1 { margin: 16px 0 24px; max-width: 18ch; }
  .g-hero em { font-style: italic; }

  .g-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .g-item { display: flex; flex-direction: column; gap: 18px; }
  .g-item.g-hidden { display: none; }
  .g-thumb-wrap { position: relative; }
  .g-thumb-link { display: block; cursor: zoom-in; }
  .g-pair-link { position: absolute; width: 0; height: 0; pointer-events: none; opacity: 0; }
  .g-thumb { aspect-ratio: 1/1; display: grid; grid-template-columns: 1fr 1fr; overflow: hidden; border: 1px solid var(--line); }
  .g-half { position: relative; overflow: hidden; }
  .g-half img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s var(--ease-out); }
  .g-item:hover .g-half img { transform: scale(1.04); }
  .g-label {
    position: absolute; bottom: 12px; left: 12px;
    font-family: var(--font-body); font-size: 0.58rem; letter-spacing: 0.3em;
    text-transform: uppercase; font-weight: 500;
    color: #f4e1e7;
    background: rgba(29,14,37,0.55);
    backdrop-filter: blur(8px);
    padding: 5px 10px;
  }
  .g-after .g-label { background: rgba(29,14,37,0.55); }
  .g-meta { padding: 0 4px; }
  .g-cat { font-size: 0.62rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--mauve-deep); font-weight: 500; }
  .g-meta h3 { font-size: 1.35rem; margin: 8px 0 6px; font-weight: 380; letter-spacing: -0.018em; }
  .g-age { font-size: 0.82rem; color: var(--grey-500); }
  @media (max-width: 900px) { .g-grid { grid-template-columns: 1fr 1fr; gap: 24px; } }
  @media (max-width: 520px) { .g-grid { grid-template-columns: 1fr; } }

  /* PhotoSwipe caption overlay */
  :global(.pswp .pswp__caption) {
    position: absolute; left: 0; right: 0; bottom: 24px;
    text-align: center;
    color: #f4e1e7;
    font-family: var(--font-body);
    pointer-events: none;
    padding: 0 24px;
  }
  :global(.pswp .cap-step) {
    display: inline-block; font-size: 0.66rem; letter-spacing: 0.32em;
    font-weight: 600; color: #d6a98b; margin-bottom: 12px;
  }
  :global(.pswp .cap-cat) {
    display: block; font-size: 0.62rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: #c89cca; margin-bottom: 6px;
  }
  :global(.pswp .cap-title) {
    display: block; font-family: var(--font-display); font-size: 1.6rem; font-weight: 360;
    letter-spacing: -0.02em; color: #f4e1e7; margin-bottom: 4px;
  }
  :global(.pswp .cap-age) { display: block; font-size: 0.78rem; color: #a8889a; }
  :global(.pswp__bg) { background: #1d0e25 !important; }
</style>
