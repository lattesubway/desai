---
import BaseLayout from '../layouts/BaseLayout.astro';
import CTASection from '../components/CTASection.astro';

const education = [
  { school: 'Harvard University', city: 'Cambridge, MA', degree: 'Master of Public Health (MPH), Health Policy' },
  { school: 'Tufts University School of Medicine', city: 'Boston, MA', degree: 'Doctor of Medicine (MD)' },
  { school: 'Harvard University', city: 'Cambridge, MA', degree: 'Graduate coursework in South Asian Art History' },
  { school: 'University of Rochester', city: 'Rochester, NY', degree: 'BS, Honors in Neuroscience, cum laude' },
  { school: 'Massachusetts Institute of Technology', city: 'Cambridge, MA', degree: 'Pre-college coursework' },
];

const training = [
  { place: 'Beverly Hills Institute of Plastic Surgery', detail: 'Advanced Aesthetic Fellowship in Plastic Surgery' },
  { place: 'University of Miami / Jackson Memorial Hospital', detail: 'Chief Resident, Plastic & Reconstructive Surgery' },
  { place: 'Miami Children\'s Hospital', detail: 'Chief Resident, Plastic & Reconstructive Surgery' },
  { place: 'Harvard Medical School / Boston Children\'s Hospital', detail: 'Resident' },
  { place: 'Brown Medical School / Rhode Island Hospital', detail: 'Chief Resident' },
  { place: 'Tufts Medical Center', detail: 'Chief Resident & General Surgery Internship' },
];

const stats = [
  { num: '20+', label: 'Years of training' },
  { num: '14', label: 'Peer-reviewed publications' },
  { num: '7', label: 'Textbook chapters' },
  { num: '4', label: 'Humanitarian missions to Haiti' },
];
---
<BaseLayout title="Meet Dr. Urmen Desai" description="Harvard-educated, double-board-certified, double-fellowship-trained plastic surgeon based in Beverly Hills.">
  <section class="about-hero">
    <div class="container about-hero-grid">
      <div class="reveal">
        <p class="eyebrow">Meet Dr. Desai</p>
        <h1>A surgeon's surgeon.</h1>
        <p class="lead">Dr. Urmen Desai, MD, MPH, FACS is a Harvard-educated, double-board-certified, double-fellowship-trained plastic, aesthetic, and reconstructive surgeon. His path — twenty years from MIT classrooms to a Beverly Hills practice — has been defined by precision, restraint, and an enduring obsession with proportion.</p>
      </div>
      <aside class="portrait reveal">
        <div class="portrait-frame" data-parallax="40">
          <img src="/assets/dr-desai-portrait2.png" alt="Dr. Urmen Desai, MD, MPH, FACS" width="420" height="525" loading="eager" class="portrait-img" />
          <p class="portrait-cap">Urmen Desai, MD MPH FACS</p>
          <p class="portrait-sub">Beverly Hills</p>
        </div>
      </aside>
    </div>
  </section>

  <section class="videos section">
    <div class="container">
      <div class="videos-head reveal center">
        <p class="eyebrow">In His Own Words</p>
        <h2>Meet Dr. Desai</h2>
      </div>
      <div class="videos-grid">
        <div class="video-card reveal">
          <div class="video-wrap">
            <iframe src="https://www.youtube.com/embed/nWaDr71rE4s" title="Dr. Desai on the Miami facial mauling case" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
          <div class="video-caption">
            <h3>Miami Facial Reconstruction</h3>
            <p>Dr. Desai discusses his involvement in the high-profile case of a facial mauling victim in Miami.</p>
          </div>
        </div>
        <div class="video-card reveal">
          <div class="video-wrap">
            <iframe src="https://www.youtube.com/embed/YsAZh9rb16s" title="Dr. Desai on bus-stop accident reconstruction" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
          <div class="video-caption">
            <h3>Trauma Reconstruction</h3>
            <p>Dr. Desai discusses his involvement with two patients injured in a horrific accident after being hit by a car at a bus stop.</p>
          </div>
        </div>
        <div class="video-card reveal">
          <div class="video-wrap">
            <iframe src="https://www.youtube.com/embed/cD5g2INZb3A" title="Dr. Desai on LeBron James' broken nose" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
          </div>
          <div class="video-caption">
            <h3>LeBron James' Broken Nose</h3>
            <p>Dr. Desai provides his expert opinion on NBA star LeBron James' broken nose.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="stats dark-section section-tight">
    <div class="container stats-grid">
      {stats.map(s => (
        <div class="stat reveal">
          <div class="stat-num">{s.num}</div>
          <div class="stat-label">{s.label}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="bio section">
    <div class="container bio-grid">
      <div class="reveal">
        <p class="eyebrow">The Journey</p>
        <h2>From Newton, to Boston, to Beverly Hills.</h2>
      </div>
      <div class="bio-prose reveal">
        <p>Born and raised in a suburb outside Boston, Dr. Desai studied pre-college mathematics and biology at the Massachusetts Institute of Technology while still in high school. He completed his undergraduate education at the University of Rochester with Honors in Neuroscience.</p>
        <p>Summer rotations took him to Harvard Medical School-Massachusetts General Hospital, to NASA's Kennedy Space Center, and ultimately to New Delhi, where he worked with the World Health Organization. He returned to Boston for graduate study in South Asian Art History at Harvard, before earning a Master of Public Health at the Harvard School of Public Health alongside his medical degree from Tufts.</p>
        <p>A medical-student cleft-lip and cleft-palate mission to rural southwest China redirected Dr. Desai from neurosurgery to plastic surgery. He completed surgical training at Tufts, Brown, Boston Children's Hospital-Harvard Medical School, and Jackson Memorial Hospital at the University of Miami, finishing as Chief Resident. He was then selected for the coveted Advanced Aesthetic Plastic Surgery fellowship at the Beverly Hills Institute of Plastic Surgery.</p>
        <p>Today, Dr. Desai practices in Beverly Hills while holding an academic attending position at Mt. Sinai and the New York Eye & Ear Infirmary of Mt. Sinai in Manhattan.</p>
      </div>
    </div>
  </section>

  <section class="credentials dark-section section">
    <div class="container">
      <div class="cred-head reveal center">
        <p class="eyebrow on-dark">Education & Training</p>
        <h2>An education built one institution at a time.</h2>
      </div>
      <div class="cred-grid">
        <div class="reveal">
          <h3>Education</h3>
          <ul class="cred-list">
            {education.map(e => (
              <li><div class="cred-school">{e.school}</div><div class="cred-city">{e.city}</div><div class="cred-detail">{e.degree}</div></li>
            ))}
          </ul>
        </div>
        <div class="reveal">
          <h3>Surgical Training</h3>
          <ul class="cred-list">
            {training.map(t => (
              <li><div class="cred-school">{t.place}</div><div class="cred-detail">{t.detail}</div></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="research section">
    <div class="container research-grid">
      <div class="reveal">
        <p class="eyebrow">Research & Publication</p>
        <h2>14 papers. 7 textbook chapters. Dozens of conferences.</h2>
      </div>
      <div class="reveal">
        <p class="lead">Dr. Desai has authored seven textbook chapters and fourteen peer-reviewed papers in journals including The Journal of Plastic and Reconstructive and Aesthetic Surgery, The Aesthetic Surgery Journal, and The Journal of Craniofacial Surgery. He has presented his work at national and international meetings, including the American Society of Aesthetic Plastic Surgery and the American Cleft Palate-Craniofacial Association.</p>
        <p class="lead">His published techniques include the surgical correction of lip deformities after silicone injection (the so-called "trout pout" reversal) and the treatment of symptomatic silicone toxicosis of the gluteal region.</p>
      </div>
    </div>
  </section>

  <section class="service dark-section section">
    <div class="container service-grid">
      <div class="reveal">
        <p class="eyebrow on-dark">Humanitarian Service</p>
        <h2>Surgery as service.</h2>
      </div>
      <div class="service-body reveal">
        <p class="lead">Dr. Desai has performed cleft-lip and cleft-palate reconstruction across four missions to Port-au-Prince, Haiti, following the 2010 earthquake. He served in rural southwest China on a Rotaplast cleft mission, worked with Mother Teresa's Missionaries of Charity in Calcutta and New Delhi, and volunteered with tsunami relief on Koh Phi Phi, Thailand in 2005.</p>
        <p class="lead">He has lectured for the American Society of Maxillofacial Surgery on the challenges of delivering cleft surgery in the underdeveloped world.</p>
      </div>
    </div>
  </section>

  <CTASection />
</BaseLayout>

<style>
  .about-hero { padding: clamp(96px, 14vw, 160px) 0 clamp(72px, 10vw, 120px); background: linear-gradient(180deg, var(--bg-warm), var(--bg)); }
  .about-hero-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: clamp(40px, 6vw, 80px); align-items: center; }
  .about-hero h1 { margin: 18px 0 28px; }
  .portrait-frame { max-width: 420px; margin-left: auto; position: relative; text-align: center; }
  .portrait-img { width: 100%; height: auto; object-fit: cover; display: block; }
  .portrait-cap { color: var(--ink); font-family: var(--font-display); font-size: 1.4rem; text-align: center; margin-top: 20px; }
  .portrait-sub { color: var(--accent-deep); font-size: 0.75rem; letter-spacing: 0.3em; text-transform: uppercase; }
  .videos-head { max-width: 600px; margin: 0 auto clamp(40px, 5vw, 64px); }
  .videos-head h2 { margin-top: 16px; }
  .videos-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .video-card { border: 1px solid var(--border-light); overflow: hidden; transition: transform 0.4s var(--ease), box-shadow 0.4s var(--ease); }
  .video-card:hover { transform: translateY(-3px); box-shadow: 0 24px 48px -24px rgba(0,0,0,0.12); }
  .video-wrap { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; }
  .video-wrap iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; }
  .video-caption { padding: 20px 24px; }
  .video-caption h3 { font-size: 1.1rem; margin-bottom: 6px; }
  .video-caption p { font-size: 0.88rem; color: var(--muted-dark); line-height: 1.5; }
  @media (max-width: 800px) { .videos-grid { grid-template-columns: 1fr; max-width: 560px; margin: 0 auto; } }
  .stats-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .stat { text-align: center; padding: 12px; }
  .stat-num { font-family: var(--font-display); font-size: clamp(2.5rem, 4vw, 3.5rem); color: var(--accent-soft); }
  .stat-label { font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted-light); margin-top: 8px; }
  .bio-grid { display: grid; grid-template-columns: 1fr 1.3fr; gap: clamp(40px, 8vw, 96px); align-items: start; }
  .bio-prose p { margin-bottom: 20px; color: var(--muted-dark); line-height: 1.85; }
  .cred-head { max-width: 700px; margin: 0 auto clamp(48px, 6vw, 72px); }
  .cred-head h2 { margin-top: 16px; }
  .cred-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(40px, 6vw, 80px); }
  .cred-grid h3 { color: var(--accent-soft); margin-bottom: 28px; }
  .cred-list { list-style: none; display: flex; flex-direction: column; gap: 24px; }
  .cred-list li { padding-bottom: 20px; border-bottom: 1px solid var(--border-dark); }
  .cred-school { color: var(--text-light); font-weight: 500; }
  .cred-city, .cred-detail { color: var(--muted-light); font-size: 0.9rem; margin-top: 4px; }
  .research-grid, .service-grid { display: grid; grid-template-columns: 1fr 1.3fr; gap: clamp(40px, 8vw, 96px); align-items: start; }
  .service-body p { margin-bottom: 20px; }
  @media (max-width: 800px) {
    .about-hero-grid, .bio-grid, .cred-grid, .research-grid, .service-grid { grid-template-columns: 1fr; }
    .portrait-frame { margin: 0 auto; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
