---
import type { Procedure } from '../data/procedures';
interface Props { items: Procedure[]; category: string; }
const { items, category } = Astro.props;
const allSameCategory = items.every((p) => p.category === category);
const heading = allSameCategory
  ? `Other ${category.toLowerCase()} procedures.`
  : 'You may also be interested in.';
---
{items.length > 0 && (
  <section class="related section">
    <div class="container">
      <header class="rel-h reveal">
        <div>
          <p class="eyebrow">Related</p>
          <h2>{heading}</h2>
        </div>
        <a href="/procedures" class="rel-all">View all procedures →</a>
      </header>
      <div class="rel-grid">
        {items.map((p, i) => (
          <a href={`/procedures/${p.slug}`} class="rel-card reveal" style={`transition-delay:${i*60}ms`}>
            <span class="rel-cat">{p.category}</span>
            <h3>{p.title}</h3>
            <p>{p.blurb}</p>
            <span class="rel-link">Read more <span class="arrow">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .related { background: var(--bg-warm); padding-top: clamp(64px, 8vw, 96px); padding-bottom: clamp(64px, 8vw, 96px); }
  .rel-h { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 36px; flex-wrap: wrap; }
  .rel-h h2 { margin-top: 14px; max-width: 18ch; }
  .rel-all { font-family: var(--font-display); font-size: 0.78rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--aubergine); border-bottom: 1px solid var(--rose); padding-bottom: 4px; transition: color 0.3s var(--ease), border-color 0.3s var(--ease); }
  .rel-all:hover { color: var(--mauve); border-bottom-color: var(--mauve); }
  .rel-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 18px; }
  .rel-card { display: flex; flex-direction: column; gap: 12px; padding: 28px; background: var(--paper); border: 1px solid var(--border-light); transition: transform 0.4s var(--ease), border-color 0.4s var(--ease), background 0.4s var(--ease), color 0.4s var(--ease); min-height: 240px; }
  .rel-card:hover { transform: translateY(-3px); background: var(--aubergine); border-color: var(--aubergine); color: var(--paper); }
  .rel-cat { font-size: 0.68rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--mauve); font-family: var(--font-display); font-weight: 500; }
  .rel-card:hover .rel-cat { color: var(--rose); }
  .rel-card h3 { font-size: 1.4rem; }
  .rel-card:hover h3 { color: var(--paper); }
  .rel-card p { color: var(--muted); font-size: 0.92rem; flex-grow: 1; }
  .rel-card:hover p { color: var(--rose-soft); }
  .rel-link { font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--aubergine); display: inline-flex; gap: 8px; align-items: center; margin-top: auto; }
  .rel-card:hover .rel-link { color: var(--rose); }
  .arrow { transition: transform 0.4s var(--ease); display: inline-block; }
  .rel-card:hover .arrow { transform: translateX(4px); }
  @media (max-width: 860px) { .rel-grid { grid-template-columns: 1fr; } }
</style>
