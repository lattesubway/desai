---
import { SITE } from '../consts';
---
<div class="sticky-cta" role="region" aria-label="Quick contact">
  <a href={`tel:${SITE.phoneRaw}`} class="sc-call" aria-label={`Call ${SITE.phone}`}>
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
    <span>Call</span>
  </a>
  <a href="/consultation/" class="sc-book">Schedule Consultation</a>
</div>

<style>
  .sticky-cta { display: none; }
  @media (max-width: 860px) {
    .sticky-cta { display: flex; gap: 8px; position: fixed; left: 12px; right: 12px; bottom: 12px; z-index: 60; padding: 8px; background: rgba(38,20,40,0.95); backdrop-filter: blur(14px); border-radius: 999px; box-shadow: 0 20px 50px -20px rgba(38,20,40,0.6); }
    .sc-call, .sc-book { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 12px 18px; font-family: var(--font-display); font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 500; border-radius: 999px; transition: background 0.3s var(--ease), color 0.3s var(--ease); }
    .sc-call { background: transparent; color: var(--paper); border: 1px solid rgba(246,243,238,0.3); }
    .sc-call:hover { background: rgba(246,243,238,0.1); color: var(--paper); }
    .sc-book { flex: 1; background: var(--rose); color: var(--aubergine); }
    .sc-book:hover { background: var(--paper); color: var(--aubergine); }
    main { padding-bottom: 84px; }
  }
  @media (prefers-reduced-motion: reduce) { .sticky-cta { transition: none; } }
</style>
