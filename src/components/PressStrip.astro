---
const outlets = [
  { name: 'CNN', file: 'cnn.png' },
  { name: 'ABC News', file: 'abc-news.png' },
  { name: 'NBC', file: 'nbc.png' },
  { name: 'Fox News', file: 'fox-news.svg' },
  { name: 'CBS', file: 'cbs.png' },
  { name: 'Good Morning America', file: 'good-morning-america.png' },
  { name: 'The Guardian', file: 'the-guardian.png' },
  { name: 'NY Daily News', file: 'ny-daily-news.png' },
];
---
<section class="press section-tight">
  <div class="container">
    <p class="eyebrow center reveal">As Featured In</p>
    <div class="press-marquee reveal">
      <div class="press-track">
        {outlets.map(o => <span class="press-mark"><img src={`/assets/${o.file}`} alt={o.name} width="120" height="40" loading="lazy" /></span>)}
        {outlets.map(o => <span class="press-mark" aria-hidden="true"><img src={`/assets/${o.file}`} alt="" width="120" height="40" loading="lazy" /></span>)}
      </div>
    </div>
  </div>
</section>

<style>
  .press { background: var(--bg-warm); border-top: 1px solid var(--border-light); border-bottom: 1px solid var(--border-light); }
  .press-marquee { overflow: hidden; margin-top: 24px; mask-image: linear-gradient(90deg, transparent, black 10%, black 90%, transparent); }
  .press-track { display: flex; gap: 64px; align-items: center; animation: scroll 40s linear infinite; width: max-content; }
  .press-mark { display: flex; align-items: center; white-space: nowrap; }
  .press-mark img { height: clamp(24px, 4vw, 40px); width: auto; object-fit: contain; opacity: 0.7; filter: grayscale(100%); transition: opacity 0.3s var(--ease), filter 0.3s var(--ease); }
  .press-mark:hover img { opacity: 1; filter: grayscale(0%); }
  @keyframes scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
  @media (prefers-reduced-motion: reduce) { .press-track { animation: none; justify-content: center; flex-wrap: wrap; } }
</style>
