---
import { SITE } from '../consts';
---
<footer class="site-footer dark-section">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/assets/logo.png" alt="Desai Plastic Surgery" class="footer-logo" width="200" height="48" loading="lazy" />
        <p class="muted-on-dark">{SITE.tagline}</p>
        <div class="social-links">
          <a href={SITE.social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">Instagram</a>
          <a href={SITE.social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">Facebook</a>
          <a href={SITE.social.youtube} target="_blank" rel="noopener noreferrer" aria-label="YouTube">YouTube</a>
          <a href={SITE.social.snapchat} target="_blank" rel="noopener noreferrer" aria-label="Snapchat">Snapchat</a>
          <a href={SITE.social.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">LinkedIn</a>
          <a href={SITE.social.google} target="_blank" rel="noopener noreferrer" aria-label="Google">Google</a>
        </div>
      </div>
      <div>
        <h4>Practice</h4>
        <ul><li><a href="/about">About Dr. Desai</a></li><li><a href="/procedures">Procedures</a></li><li><a href="/gallery">Gallery</a></li><li><a href="/media">Media</a></li><li><a href="/reviews">Reviews</a></li></ul>
      </div>
      <div>
        <h4>Visit</h4>
        <address>
          {SITE.address.street}<br/>
          {SITE.address.city}, {SITE.address.state} {SITE.address.zip}
        </address>
        <p><a href={`tel:${SITE.phoneRaw}`}>{SITE.phone}</a></p>
        <p class="fax">Fax {SITE.fax}</p>
      </div>
      <div>
        <h4>Begin</h4>
        <p>Complimentary virtual or in-person consultation.</p>
        <a href="/consultation" class="btn btn-ghost">Schedule <span class="arrow">→</span></a>
      </div>
    </div>
    <div class="footer-base">
      <small>© {new Date().getFullYear()} {SITE.name}. All rights reserved.</small>
      <small>Models pictured may not be actual patients.</small>
    </div>
  </div>
</footer>

<style>
  .site-footer { padding: clamp(64px, 8vw, 96px) 0 32px; }
  .footer-grid { display: grid; grid-template-columns: 1.4fr 1fr 1fr 1fr; gap: 48px; padding-bottom: 64px; border-bottom: 1px solid var(--border-dark); }
  .footer-logo { height: 64px; width: auto; filter: brightness(0) invert(1); }
  .muted-on-dark { color: var(--muted-light); margin-top: 12px; font-size: 0.95rem; }
  .social-links { display: flex; flex-wrap: wrap; gap: 24px; margin-top: 28px; }
  .social-links a { padding: 6px 0; font-size: 0.62rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--text-light); font-weight: 500; transition: opacity 0.3s var(--ease); }
  .social-links a:hover { opacity: 0.55; }
  h4 { font-family: var(--font-body); font-size: 0.62rem; letter-spacing: 0.3em; text-transform: uppercase; color: var(--paper); margin-bottom: 24px; font-weight: 500; }
  ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  ul a, address a { color: var(--text-light); transition: color 0.3s ease; }
  ul a:hover, address a:hover { color: var(--grey-300); opacity: 1; }
  ul a, address a { font-size: 0.9rem; letter-spacing: -0.005em; }
  address { font-style: normal; line-height: 1.7; color: var(--text-light); margin-bottom: 12px; }
  .fax { color: var(--muted-light); font-size: 0.9rem; margin-top: 4px; }
  .footer-base { display: flex; justify-content: space-between; padding-top: 32px; color: var(--muted-light); flex-wrap: wrap; gap: 12px; }
  @media (max-width: 900px) { .footer-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 560px) { .footer-grid { grid-template-columns: 1fr; gap: 36px; } }
</style>
