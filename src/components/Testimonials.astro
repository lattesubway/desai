---
import { testimonials } from '../data/testimonials';
---
<section class="testimonials section dark-section">
  <div class="container">
    <div class="t-head reveal">
      <p class="eyebrow on-dark">In Their Words</p>
      <h2>What patients say.</h2>
    </div>
    <div class="t-grid">
      {testimonials.map((t, i) => (
        <figure class="t-card reveal" style={`transition-delay:${i*100}ms`}>
          <span class="quote-mark">"</span>
          <blockquote>{t.quote}</blockquote>
          <figcaption>— {t.author}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .t-head { text-align: center; margin-bottom: clamp(48px, 6vw, 72px); }
  .t-head h2 { margin-top: 16px; }

  .t-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1px;
    background: var(--border-dark);
    border: 1px solid var(--border-dark);
  }
  @media (min-width: 1200px) {
    .t-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .t-card {
    background: var(--ink);
    padding: clamp(40px, 4.5vw, 64px);
    display: flex;
    flex-direction: column;
    gap: 18px;
    position: relative;
  }
  /* Subtle top hairline for refined depth (luxe editorial feel) */
  .t-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--line-soft), transparent);
    opacity: 0.6;
  }

  .quote-mark {
    font-family: var(--font-display);
    font-size: 3.25rem;
    color: var(--accent);
    line-height: 0.8;
    margin-bottom: -4px;
    opacity: 0.85;
  }

  blockquote {
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1.65vw, 1.38rem);
    line-height: 1.58;
    font-style: italic;
    color: var(--text-light);
    max-width: 42ch;
  }

  figcaption {
    margin-top: 4px;
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--accent-soft);
    font-weight: 500;
  }

  @media (max-width: 700px) {
    .t-grid { grid-template-columns: 1fr; }
    .t-card { padding: 36px 28px; }
    blockquote { max-width: none; }
  }
</style>
