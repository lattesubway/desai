---
import { Icon } from 'astro-icon/components';
import { procedures } from '../data/procedures';
const items = [
  { label: 'Home', href: '/', kind: 'Page' },
  { label: 'About Dr. Desai', href: '/about/', kind: 'Page' },
  { label: 'All Procedures', href: '/procedures/', kind: 'Page' },
  { label: 'Before & After Gallery', href: '/gallery/', kind: 'Page' },
  { label: 'Media & Press', href: '/media/', kind: 'Page' },
  { label: 'Patient Reviews', href: '/reviews/', kind: 'Page' },
  { label: 'Contact', href: '/contact/', kind: 'Page' },
  { label: 'Schedule a Consultation', href: '/consultation/', kind: 'Action' },
  ...procedures.map((p) => ({
    label: p.title, href: `/procedures/${p.slug}/`, kind: p.category,
  })),
];
---
<dialog class="sp" id="sp-dialog" aria-label="Search the site">
  <div class="sp-inner">
    <div class="sp-input-wrap">
      <Icon name="lucide:search" size={18} aria-hidden="true" />
      <input id="sp-input" type="search" placeholder="Search procedures, pages, content…" autocomplete="off" />
      <button type="button" class="sp-close" id="sp-close" aria-label="Close">Esc</button>
    </div>
    <div class="sp-body" id="sp-body">
      <section class="sp-section" id="sp-jump">
        <header class="sp-section-h">Jump to</header>
        <ul class="sp-list" id="sp-list" role="listbox" aria-label="Page navigation"></ul>
      </section>
      <section class="sp-section" id="sp-deep" hidden>
        <header class="sp-section-h">From the site</header>
        <ul class="sp-results" id="sp-results" role="listbox" aria-label="Full-text search results"></ul>
      </section>
    </div>
    <footer class="sp-foot">
      <span><kbd>↑</kbd><kbd>↓</kbd> navigate</span>
      <span><kbd>↵</kbd> select</span>
      <span><kbd>esc</kbd> close</span>
    </footer>
  </div>
</dialog>

<script is:inline define:vars={{ items }}>
  (() => {
    const init = () => {
      const dialog = document.getElementById('sp-dialog');
      const input = document.getElementById('sp-input');
      const list = document.getElementById('sp-list');
      const results = document.getElementById('sp-results');
      const deepSection = document.getElementById('sp-deep');
      const close = document.getElementById('sp-close');
      if (!dialog || !input || !list || !results || !deepSection || !close) return;
      if (dialog.dataset.bound) return;
      dialog.dataset.bound = '1';

      let active = 0;        // active index over the *combined* flat list
      let jumpItems = items; // current page-jump matches
      let deepItems = [];    // current pagefind matches
      let pagefind = null;
      let pagefindFailed = false;

      // Lazy-load pagefind on first input
      const loadPagefind = async () => {
        if (pagefind || pagefindFailed) return;
        try {
          pagefind = await import(/* @vite-ignore */ '/pagefind/pagefind.js');
          await pagefind.options({ baseUrl: '/' });
        } catch (e) {
          pagefindFailed = true; // dev mode, or pagefind not built
        }
      };

      const flat = () => [
        ...jumpItems.map((i) => ({ ...i, _kind: 'jump' })),
        ...deepItems.map((i) => ({ ...i, _kind: 'deep' })),
      ];

      const renderJump = () => {
        if (active >= flat().length) active = 0;
        list.innerHTML = jumpItems.length
          ? jumpItems.map((i, idx) => `
            <li role="option" data-idx="${idx}" data-kind="jump" aria-selected="${idx === active}">
              <span class="lbl">${escapeHtml(i.label)}</span>
              <span class="kind">${escapeHtml(i.kind)}</span>
            </li>`).join('')
          : (input.value ? '' : '<li class="empty">Type to search.</li>');
      };

      const renderDeep = () => {
        if (!deepItems.length) {
          deepSection.hidden = true;
          results.innerHTML = '';
          return;
        }
        deepSection.hidden = false;
        const offset = jumpItems.length;
        results.innerHTML = deepItems.map((r, i) => {
          const idx = offset + i;
          return `
            <li role="option" data-idx="${i}" data-kind="deep" aria-selected="${idx === active}">
              <div class="r-row">
                <span class="r-title">${r.meta_title || r.title || r.url}</span>
                <span class="r-excerpt">${r.excerpt}</span>
              </div>
            </li>`;
        }).join('');
      };

      const escapeHtml = (s) => String(s).replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));

      const filterJump = (q) => {
        const t = q.trim().toLowerCase();
        return !t ? items : items.filter((i) =>
          i.label.toLowerCase().includes(t) || i.kind.toLowerCase().includes(t)
        );
      };

      let deepReq = 0;
      const searchDeep = async (q) => {
        const reqId = ++deepReq;
        if (!q.trim() || q.trim().length < 2) { deepItems = []; renderDeep(); return; }
        await loadPagefind();
        if (!pagefind) return;
        const r = await pagefind.debouncedSearch(q, { limit: 5 });
        if (!r || reqId !== deepReq) return; // stale
        const top = await Promise.all(r.results.slice(0, 5).map((x) => x.data()));
        deepItems = top.map((d) => ({
          title: d.meta?.title || d.url,
          meta_title: d.meta?.title,
          excerpt: d.excerpt,
          url: d.url,
        }));
        renderDeep();
      };

      const onInput = () => {
        active = 0;
        jumpItems = filterJump(input.value);
        renderJump();
        searchDeep(input.value);
      };

      const open = () => {
        if (dialog.open) return;
        active = 0;
        input.value = '';
        jumpItems = items;
        deepItems = [];
        renderJump();
        renderDeep();
        dialog.showModal();
        setTimeout(() => input.focus(), 10);
      };
      const shut = () => { if (dialog.open) dialog.close(); };

      const go = (item) => {
        if (!item) return;
        shut();
        location.href = item.href || item.url;
      };

      document.querySelectorAll('[data-search-trigger]').forEach((el) => {
        if (el.dataset.bound) return;
        el.dataset.bound = '1';
        el.addEventListener('click', open);
      });
      close.addEventListener('click', shut);
      dialog.addEventListener('click', (e) => { if (e.target === dialog) shut(); });
      input.addEventListener('input', onInput);

      const click = (e) => {
        const li = e.target.closest('li[data-idx]');
        if (!li) return;
        const idx = +li.dataset.idx;
        const kind = li.dataset.kind;
        const item = kind === 'jump' ? jumpItems[idx] : deepItems[idx];
        go(item);
      };
      list.addEventListener('click', click);
      results.addEventListener('click', click);

      const updateSelection = () => {
        const combined = flat();
        list.querySelectorAll('li[data-kind="jump"]').forEach((el, i) =>
          el.setAttribute('aria-selected', String(i === active)));
        results.querySelectorAll('li[data-kind="deep"]').forEach((el, i) =>
          el.setAttribute('aria-selected', String((jumpItems.length + i) === active)));
        const sel = document.querySelector('.sp [aria-selected="true"]');
        sel?.scrollIntoView({ block: 'nearest' });
      };

      input.addEventListener('keydown', (e) => {
        const combined = flat();
        if (e.key === 'ArrowDown') {
          e.preventDefault();
          active = Math.min(active + 1, combined.length - 1);
          updateSelection();
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          active = Math.max(active - 1, 0);
          updateSelection();
        } else if (e.key === 'Enter') {
          e.preventDefault();
          go(combined[active]);
        }
      });
      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') { e.preventDefault(); dialog.open ? shut() : open(); }
        else if (e.key === '/' && !/^(INPUT|TEXTAREA|SELECT)$/.test(document.activeElement?.tagName || '')) { e.preventDefault(); open(); }
        else if (e.key === 'Escape' && dialog.open) shut();
      });

      renderJump();
    };
    init();
    document.addEventListener('astro:after-swap', init);
  })();
</script>

<style is:global>
  .search-trigger { display: inline-flex; align-items: center; gap: 10px; height: 32px; padding: 0; border: 0; background: transparent; color: var(--ink); border-radius: 0; cursor: pointer; transition: opacity 0.3s var(--ease); font-family: var(--font-body); font-size: 0.66rem; letter-spacing: 0.28em; text-transform: uppercase; font-weight: 500; }
  .search-trigger:hover { opacity: 0.55; color: var(--ink); }
  .search-trigger kbd { font: 500 10px/1 ui-monospace, monospace; background: transparent; border: 1px solid var(--line-strong); color: var(--grey-500); padding: 2px 5px; border-radius: 0; letter-spacing: 0.04em; }
  @media (max-width: 980px) { .search-trigger kbd { display: none; } }

  .sp { border: 1px solid var(--ink); border-radius: 0; padding: 0; max-width: 640px; width: calc(100% - 32px); background: var(--paper); color: var(--ink); margin: 12vh auto auto; box-shadow: 0 40px 80px -20px rgba(0,0,0,0.3); }
  .sp::backdrop { background: rgba(0, 0, 0, 0.55); backdrop-filter: blur(6px); }
  .sp[open] { animation: spOpen 0.18s var(--ease); }
  @keyframes spOpen { from { transform: translateY(8px); opacity: 0; } }

  .sp-inner { display: flex; flex-direction: column; }
  .sp-input-wrap { display: flex; align-items: center; gap: 12px; padding: 18px 20px; border-bottom: 1px solid var(--line); color: var(--mauve); }
  .sp-input-wrap input { flex: 1; border: 0; outline: 0; font: 400 16px/1.4 var(--font-body); background: transparent; color: var(--ink); }
  .sp-input-wrap input::placeholder { color: var(--grey-500); }
  .sp-close { font: 500 10px/1 ui-monospace, monospace; padding: 4px 8px; background: transparent; border: 1px solid var(--line); color: var(--grey-500); border-radius: 0; cursor: pointer; }

  .sp-body { max-height: 60vh; overflow-y: auto; }
  .sp-section { padding: 6px 0; }
  .sp-section + .sp-section { border-top: 1px solid var(--line); }
  .sp-section-h {
    padding: 12px 20px 6px; font-family: var(--font-body);
    font-size: 0.6rem; letter-spacing: 0.32em; text-transform: uppercase;
    color: var(--grey-500); font-weight: 600;
  }

  .sp-list, .sp-results { list-style: none; padding: 4px 8px 8px; margin: 0; }
  .sp-list li, .sp-results li { display: flex; justify-content: space-between; align-items: center; gap: 12px; padding: 12px 14px; border-radius: 0; cursor: pointer; color: var(--ink); font-size: 0.92rem; }
  .sp-list li[aria-selected="true"], .sp-results li[aria-selected="true"] { background: var(--paper-deep); }
  .sp-list .kind { font-size: 0.68rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--grey-500); font-family: var(--font-body); font-weight: 500; }
  .sp-list .empty { padding: 24px 14px; color: var(--grey-500); text-align: center; cursor: default; justify-content: center; }
  .sp-list .empty:hover { background: transparent; }

  .sp-results li { align-items: flex-start; }
  .r-row { display: flex; flex-direction: column; gap: 4px; min-width: 0; flex: 1; }
  .r-title { font-family: var(--font-display); font-weight: 380; letter-spacing: -0.012em; font-size: 1rem; color: var(--ink); }
  .r-excerpt { font-size: 0.82rem; color: var(--grey-500); line-height: 1.5; }
  .r-excerpt mark { background: transparent; color: var(--ink); font-weight: 500; }

  .sp-foot { display: flex; gap: 16px; padding: 10px 16px; border-top: 1px solid var(--line); color: var(--grey-500); font-size: 11px; font-family: var(--font-body); }
  .sp-foot kbd { margin-right: 4px; background: transparent; border: 1px solid var(--line); padding: 2px 6px; border-radius: 0; font: 500 10px/1 ui-monospace, monospace; color: var(--grey-500); }
</style>
